{
  "name": "m3-sdk-pdf-generator",
  "version": "1.0.0",
  "description": "M3 Mobile SDK Documentation - Professional PDF Generator with TOC and Git History",
  "main": "convert-md-to-pdf.js",
  "scripts": {
    "pdf": "node convert-md-to-pdf.js",
    "pdf:docs": "node convert-md-to-pdf.js --input ../../docs --output ../../build/release/manuals --repo-root ../.. --temp ../../build/md-to-pdf --clean",
    "test": "node convert-md-to-pdf.js --help"
  },
  "keywords": [
    "markdown",
    "pdf",
    "documentation",
    "toc",
    "git-history"
  ],
  "author": "M3 Mobile Documentation Team",
  "license": "MIT",
  "dependencies": {
    "marked": "^11.1.1",
    "simple-git": "^3.22.0"
  }
}
